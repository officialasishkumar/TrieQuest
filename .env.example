MYSQL_DATABASE=triequest
MYSQL_USER=triequest
MYSQL_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-strong-root-password
TRIEQUEST_PUBLIC_HOSTNAME=api.example.com
TRIEQUEST_ACME_EMAIL=you@example.com
TRIEQUEST_SECRET_KEY=replace-with-a-long-random-secret
# Set this to your deployed frontend origin, for example:
# https://triequest.vercel.app
TRIEQUEST_CORS_ORIGINS=https://your-frontend.example.com
# Include the public API hostname plus the local hosts used by health checks.
TRIEQUEST_ALLOWED_HOSTS=api.example.com,127.0.0.1,localhost,backend
TRIEQUEST_DATABASE_AUTO_MIGRATE=true
TRIEQUEST_SEED_DEMO_DATA=false
TRIEQUEST_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
TRIEQUEST_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
TRIEQUEST_FRIEND_LOOKUP_RATE_LIMIT_MAX_ATTEMPTS=20
TRIEQUEST_FRIEND_LOOKUP_RATE_LIMIT_WINDOW_SECONDS=60
TRIEQUEST_ENABLE_DOCS=false
TRIEQUEST_WEB_CONCURRENCY=1
TRIEQUEST_FORWARDED_ALLOW_IPS=*
# Keep /api only when the frontend is reverse-proxied together with the backend.
# If the frontend is deployed separately, rebuild it with
# VITE_API_BASE_URL=https://api.example.com instead.
VITE_API_BASE_URL=/api
