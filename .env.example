MYSQL_DATABASE=triequest
MYSQL_USER=triequest
MYSQL_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-strong-root-password
TRIEQUEST_SECRET_KEY=replace-with-a-long-random-secret
# Render / hosted MySQL-compatible database:
# mysql://USER:PASSWORD@HOST:4000/triequest?parseTime=true&charset=utf8mb4
TRIEQUEST_DATABASE_URL=mysql://user:password@host:4000/triequest?parseTime=true&charset=utf8mb4
# Enable TLS for hosted MySQL-compatible databases such as TiDB Cloud Starter.
TRIEQUEST_DATABASE_SSL_CA_PATH=/etc/ssl/certs/ca-certificates.crt
TRIEQUEST_DATABASE_SSL_VERIFY_CERT=true
TRIEQUEST_DATABASE_SSL_VERIFY_IDENTITY=true
# Set this to your deployed frontend origin, for example:
# https://trie-quest.vercel.app
TRIEQUEST_CORS_ORIGINS=https://trie-quest.vercel.app
# Render host plus local hosts used by health checks.
TRIEQUEST_ALLOWED_HOSTS=triequest-api.onrender.com,127.0.0.1,localhost
TRIEQUEST_DATABASE_AUTO_MIGRATE=false
TRIEQUEST_SEED_DEMO_DATA=false
TRIEQUEST_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
TRIEQUEST_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
TRIEQUEST_FRIEND_LOOKUP_RATE_LIMIT_MAX_ATTEMPTS=20
TRIEQUEST_FRIEND_LOOKUP_RATE_LIMIT_WINDOW_SECONDS=60
TRIEQUEST_ENABLE_ADMIN=false
TRIEQUEST_ADMIN_EMAILS=
TRIEQUEST_ADMIN_RATE_LIMIT_MAX_ATTEMPTS=5
TRIEQUEST_ADMIN_RATE_LIMIT_WINDOW_SECONDS=300
TRIEQUEST_ENABLE_DOCS=false
# TiDB Cloud Starter closes idle connections after 5 minutes; recycle pooled
# connections early to avoid stale pooled sessions on Render.
TRIEQUEST_DATABASE_POOL_RECYCLE_SECONDS=300
TRIEQUEST_SESSION_COOKIE_NAME=triequest-admin-session
# Separate frontend deployments should use an absolute API URL.
VITE_API_BASE_URL=https://triequest-api.onrender.com
